{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "paths": {
      "@bookmarkly/shared": ["../../packages/shared/types.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
