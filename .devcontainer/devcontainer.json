{
  "name": "WebApp Starterkit",
  "runArgs": ["--name", "bookmarkly"],
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "forwardPorts": [5173, 3000],
  "postCreateCommand": "npm install && curl -sSfL https://get.tur.so/install.sh | bash",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/node/.turso/bin"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
